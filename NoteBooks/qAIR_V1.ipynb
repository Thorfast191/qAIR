"""#  Load LLM (Frozen)"""

import torch
import pennylane as qml
import time
import re
import matplotlib.pyplot as plt
from datasets import load_dataset
from transformers import AutoTokenizer, AutoModelForCausalLM

# =========================
# 1. DEVICE
# =========================
device = "cuda" if torch.cuda.is_available() else "cpu"

# =========================
# 2. LOAD MODEL (TinyLlama)
# =========================
model_name = "TinyLlama/TinyLlama-1.1B-Chat-v1.0"

tokenizer = AutoTokenizer.from_pretrained(model_name)

model = AutoModelForCausalLM.from_pretrained(
    model_name,
    torch_dtype=torch.float16 if device == "cuda" else torch.float32,
    device_map="auto"
)

if tokenizer.pad_token is None:
    tokenizer.pad_token = tokenizer.eos_token

model.eval()

"""# Quantum Config"""

n_qubits = 3
dim = 2 ** n_qubits

dev = qml.device("lightning.qubit", wires=n_qubits)

# trainable quantum weights
weights = torch.randn(n_qubits * 2, requires_grad=True)

"""# Quantum Circuit"""

# =========================
@qml.qnode(dev, interface="torch")
def reasoning_circuit(amplitudes, weights):

    qml.AmplitudeEmbedding(amplitudes, wires=range(n_qubits), normalize=True)

    for i in range(n_qubits):
        qml.RY(weights[i], wires=i)

    idx = n_qubits
    for i in range(n_qubits):
        for j in range(i + 1, n_qubits):
            qml.CRY(weights[idx], wires=[i, j])
            idx += 1

    return qml.probs(wires=range(n_qubits))

"""# PROMPT FORMAT"""

def build_prompt(question):
    return f"""<|system|>
You are a precise math solver.

<|user|>
{question}

Solve step by step and end with:
Final Answer: <number>

<|assistant|>
"""

"""# GENERATE CANDIDATES"""

def generate_candidates(prompt, num_candidates=4):

    inputs = tokenizer(build_prompt(prompt), return_tensors="pt").to(device)

    outputs = model.generate(
        **inputs,
        max_new_tokens=25,
        num_beams=num_candidates,              # 🔥 beam search
        num_return_sequences=num_candidates,   # multiple outputs
        early_stopping=True,
        do_sample=False                        # still deterministic
    )

    return [
        tokenizer.decode(o, skip_special_tokens=True)
        for o in outputs
    ]

"""# ENCODE CANDIDATES"""

def encode_candidates(candidates):

    scores = []

    for text in candidates:
        inputs = tokenizer(text, return_tensors="pt").to(device)
        outputs = model(**inputs)
        scores.append(torch.mean(outputs.logits).item())

    scores = torch.tensor(scores)
    probs = torch.softmax(scores, dim=0)

    if len(probs) < dim:
        probs = torch.cat([probs, torch.zeros(dim - len(probs))])

    amplitudes = torch.sqrt(probs)
    return amplitudes

"""# QUANTUM SELECTION"""

def quantum_select(candidates):
    amplitudes = encode_candidates(candidates)
    probs = reasoning_circuit(amplitudes, weights)
    return candidates[torch.argmax(probs)]

"""# CLASSICAL SELECTION"""

def generate_classical(prompt):

    inputs = tokenizer(build_prompt(prompt), return_tensors="pt").to(device)

    outputs = model.generate(
        **inputs,
        max_new_tokens=60,
        do_sample=False
    )

    return tokenizer.decode(outputs[0], skip_special_tokens=True)

"""# REASONING LOOP"""

def quantum_reasoning(prompt):
    candidates = generate_candidates(prompt)
    return quantum_select(candidates)

"""#  HELPER (ANSWER EXTRACTION)"""

def extract_number(text):

    match = re.search(r"Final Answer:\s*(\d+)", text)
    if match:
        return match.group(1)

    nums = re.findall(r"\d+", text)
    return nums[-1] if nums else None

"""# LOAD GSM8K"""

dataset = load_dataset("gsm8k", "main", split="test[:5]")  # small batch

"""# Testing"""

from tqdm import tqdm

total = len(dataset)

classical_correct = 0
quantum_correct = 0

classical_times = []
quantum_times = []

for i, sample in enumerate(tqdm(dataset, desc="Evaluating GSM8K")):

    print(f"\nRunning sample {i+1}")

    question = sample["question"]
    answer = extract_number(sample["answer"])

    # Classical
    t1 = time.time()
    c_out = generate_classical(question)
    t2 = time.time()

    # Quantum
    t3 = time.time()
    q_out = quantum_reasoning(question)
    t4 = time.time()

    c_ans = extract_number(c_out)
    q_ans = extract_number(q_out)

    if c_ans is not None and answer is not None and c_ans == answer:
        classical_correct += 1

    if q_ans is not None and answer is not None and q_ans == answer:
        quantum_correct += 1

    classical_times.append(t2 - t1)
    quantum_times.append(t4 - t3)

    tqdm.write(
        f"[{i+1}] C_acc: {classical_correct/(i+1):.2f} | Q_acc: {quantum_correct/(i+1):.2f}"
    )

print("\n======================")
print("FINAL RESULTS")
print("======================")

print(f"Classical Accuracy: {classical_correct}/{total}")
print(f"Quantum Accuracy  : {quantum_correct}/{total}")

print(f"Avg Classical Time: {sum(classical_times)/total:.4f}s")
print(f"Avg Quantum Time  : {sum(quantum_times)/total:.4f}s")

labels = ["Classical", "Quantum"]
accuracy = [classical_correct/total, quantum_correct/total]
time_avg = [sum(classical_times)/total, sum(quantum_times)/total]

plt.figure()
plt.title("Accuracy Comparison")
plt.bar(labels, accuracy)
plt.ylabel("Accuracy")

plt.figure()
plt.title("Time Comparison")
plt.bar(labels, time_avg)
plt.ylabel("Seconds")

plt.show()

"""# DeepSeek"""

import torch
import pennylane as qml
import time
import re
import matplotlib.pyplot as plt
from datasets import load_dataset
from transformers import AutoTokenizer, AutoModelForCausalLM
from tqdm import tqdm

# =========================
# 1. DEVICE
# =========================
device = "cuda" if torch.cuda.is_available() else "cpu"

# =========================
# 2. LOAD MODEL (Frozen)
# =========================
model_name = "TinyLlama/TinyLlama-1.1B-Chat-v1.0"

tokenizer = AutoTokenizer.from_pretrained(model_name)
model = AutoModelForCausalLM.from_pretrained(
    model_name,
    torch_dtype=torch.float16 if device == "cuda" else torch.float32,
    device_map="auto"
)
if tokenizer.pad_token is None:
    tokenizer.pad_token = tokenizer.eos_token
model.eval()

# =========================
# 3. QUANTUM CONFIGURATION
# =========================
n_qubits = 3
dim = 2 ** n_qubits
dev = qml.device("lightning.qubit", wires=n_qubits)

# Trainable quantum weights – we will train them
weights = torch.randn(n_qubits * 2, requires_grad=True)

# Quantum circuit
@qml.qnode(dev, interface="torch")
def reasoning_circuit(amplitudes, weights):
    qml.AmplitudeEmbedding(amplitudes, wires=range(n_qubits), normalize=True)
    for i in range(n_qubits):
        qml.RY(weights[i], wires=i)
    idx = n_qubits
    for i in range(n_qubits):
        for j in range(i + 1, n_qubits):
            qml.CRY(weights[idx], wires=[i, j])
            idx += 1
    return qml.probs(wires=range(n_qubits))

# =========================
# 4. PROMPT FORMATTING
# =========================
def build_prompt(question):
    return f"""<|system|>
You are a precise math solver.

<|user|>
{question}

Solve step by step and end with:
Final Answer: <number>

<|assistant|>
"""

# =========================
# 5. CANDIDATE GENERATION
# =========================
def generate_candidates(prompt, num_candidates=4):
    inputs = tokenizer(build_prompt(prompt), return_tensors="pt").to(device)
    outputs = model.generate(
        **inputs,
        max_new_tokens=25,
        num_beams=num_candidates,
        num_return_sequences=num_candidates,
        early_stopping=True,
        do_sample=False
    )
    return [tokenizer.decode(o, skip_special_tokens=True) for o in outputs]

# =========================
# 6. ENCODE CANDIDATES (BATCHED)
# =========================
def encode_candidates(candidates):
    # Tokenize all candidates together with padding
    inputs = tokenizer(candidates, return_tensors="pt", padding=True).to(device)
    with torch.no_grad():
        outputs = model(**inputs)
    # Take mean over token dimension (excluding padding tokens)
    # Here we compute mean of logits for all tokens (simple approach)
    # A better approach: use only the logits of the last token or a [EOS] token
    scores = outputs.logits.mean(dim=1)  # shape (num_candidates, vocab_size)
    # Take mean over vocabulary (not ideal but keeps your original logic)
    scores = scores.mean(dim=1)          # shape (num_candidates,)
    probs = torch.softmax(scores, dim=0)
    # Pad to dimension dim
    if len(probs) < dim:
        probs = torch.cat([probs, torch.zeros(dim - len(probs))])
    amplitudes = torch.sqrt(probs)
    return amplitudes

# =========================
# 7. QUANTUM SELECTION
# =========================
def quantum_select(candidates):
    amplitudes = encode_candidates(candidates)
    probs = reasoning_circuit(amplitudes, weights)
    # Only consider the first len(candidates) probabilities
    idx = torch.argmax(probs[:len(candidates)])
    return candidates[idx]

# =========================
# 8. CLASSICAL GENERATION (Greedy)
# =========================
def generate_classical(prompt):
    inputs = tokenizer(build_prompt(prompt), return_tensors="pt").to(device)
    outputs = model.generate(
        **inputs,
        max_new_tokens=60,
        do_sample=False
    )
    return tokenizer.decode(outputs[0], skip_special_tokens=True)

# =========================
# 9. ANSWER EXTRACTION
# =========================
def extract_number(text):
    match = re.search(r"Final Answer:\s*(\d+)", text)
    if match:
        return match.group(1)
    nums = re.findall(r"\d+", text)
    return nums[-1] if nums else None

# =========================
# 10. OPTIONAL: TRAINING LOOP
# =========================
def train_quantum_circuit(dataset, num_epochs=1, lr=0.01):
    optimizer = torch.optim.Adam([weights], lr=lr)
    loss_fn = torch.nn.CrossEntropyLoss()
    for epoch in range(num_epochs):
        epoch_loss = 0
        for sample in tqdm(dataset, desc=f"Epoch {epoch+1}"):
            question = sample["question"]
            correct_answer = extract_number(sample["answer"])
            if correct_answer is None:
                continue
            # Generate candidates
            candidates = generate_candidates(question, num_candidates=4)
            # Find index of correct candidate (if present)
            correct_idx = None
            for i, cand in enumerate(candidates):
                if extract_number(cand) == correct_answer:
                    correct_idx = i
                    break
            if correct_idx is None:
                continue  # skip if correct not in candidates
            # Encode candidates and get quantum probs
            amplitudes = encode_candidates(candidates)
            probs = reasoning_circuit(amplitudes, weights)
            # Loss: cross‑entropy between probs[:len(candidates)] and correct_idx
            logits = torch.log(probs[:len(candidates)] + 1e-8)
            loss = loss_fn(logits.unsqueeze(0), torch.tensor([correct_idx]))
            optimizer.zero_grad()
            loss.backward()
            optimizer.step()
            epoch_loss += loss.item()
        print(f"Epoch {epoch+1} loss: {epoch_loss/len(dataset):.4f}")

# =========================
# 11. MAIN EVALUATION
# =========================
# Load dataset (small subset for testing)
dataset = load_dataset("gsm8k", "main", split="test[:5]")  # change to full test for full eval

# Optional: uncomment to train the quantum circuit on the training set
# train_set = load_dataset("gsm8k", "main", split="train[:50]")
# train_quantum_circuit(train_set, num_epochs=1)

total = len(dataset)
classical_correct = 0
quantum_correct = 0
classical_times = []
quantum_times = []

for i, sample in enumerate(tqdm(dataset, desc="Evaluating GSM8K")):
    question = sample["question"]
    answer = extract_number(sample["answer"])
    if answer is None:
        continue

    # Classical
    t1 = time.time()
    c_out = generate_classical(question)
    t2 = time.time()
    c_ans = extract_number(c_out)

    # Quantum
    t3 = time.time()
    q_out = quantum_select(generate_candidates(question))
    t4 = time.time()
    q_ans = extract_number(q_out)

    if c_ans == answer:
        classical_correct += 1
    if q_ans == answer:
        quantum_correct += 1

    classical_times.append(t2 - t1)
    quantum_times.append(t4 - t3)

    tqdm.write(
        f"[{i+1}] C_acc: {classical_correct/(i+1):.2f} | Q_acc: {quantum_correct/(i+1):.2f}"
    )

print("\n======================")
print("FINAL RESULTS")
print("======================")
print(f"Classical Accuracy: {classical_correct}/{total} ({100*classical_correct/total:.1f}%)")
print(f"Quantum Accuracy  : {quantum_correct}/{total} ({100*quantum_correct/total:.1f}%)")
print(f"Avg Classical Time: {sum(classical_times)/total:.4f}s")
print(f"Avg Quantum Time  : {sum(quantum_times)/total:.4f}s")

# Plotting
labels = ["Classical", "Quantum"]
accuracy = [classical_correct/total, quantum_correct/total]
time_avg = [sum(classical_times)/total, sum(quantum_times)/total]

plt.figure()
plt.title("Accuracy Comparison")
plt.bar(labels, accuracy)
plt.ylabel("Accuracy")
plt.savefig("accuracy.png")
plt.show()

plt.figure()
plt.title("Time Comparison")
plt.bar(labels, time_avg)
plt.ylabel("Seconds")
plt.savefig("time.png")
plt.show()